<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:OverlayApp.Core.ViewModels;assembly=OverlayApp.Core"
        mc:Ignorable="d"
        x:Class="OverlayApp.Avalonia.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Overlay 설정"
        Width="640" Height="720"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DataTemplate x:Key="HotkeyEditorTemplate" DataType="vm:HotkeyEditorViewModel">
            <StackPanel Spacing="6" Margin="0,4">
                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <CheckBox Content="Ctrl" IsChecked="{Binding Ctrl}" />
                    <CheckBox Content="Alt" IsChecked="{Binding Alt}" />
                    <CheckBox Content="Shift" IsChecked="{Binding Shift}" />
                    <CheckBox Content="Win" IsChecked="{Binding Win}" />
                    <TextBlock Text="+" VerticalAlignment="Center" Margin="4,0" />
                    <TextBox Width="80" Text="{Binding Key}" />
                    <Button Content="적용" Command="{Binding ApplyCommand}" />
                </StackPanel>
                <TextBlock Text="{Binding Status}" Opacity="0.8" FontSize="12" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <TabControl>
        <TabItem Header="일반">
            <ScrollViewer>
                <StackPanel Margin="16" Spacing="20">
                    <StackPanel Spacing="6">
                        <TextBlock Text="시작 동작" FontWeight="SemiBold" />
                        <ToggleSwitch IsChecked="{Binding StartWithWindows}"
                                      OnContent="Windows 시작 시 자동 실행"
                                      OffContent="Windows 시작 시 실행 안 함" />
                        <TextBlock Text="현재 사용자의 레지스트리 Run 항목으로 등록됩니다 (관리자 권한 불필요)."
                                   TextWrapping="Wrap" Opacity="0.7" FontSize="12" />
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <TextBlock Text="위치 조정" FontWeight="SemiBold" />
                        <TextBlock Text="조정 모드를 켜면 오버레이가 노란 테두리로 표시되고 드래그로 이동, 모서리 드래그로 크기 조절 가능합니다. 끄면 클릭이 아래로 통과합니다."
                                   TextWrapping="Wrap" Opacity="0.75" FontSize="12" />
                        <ToggleSwitch IsChecked="{Binding IsAdjustMode}"
                                      OnContent="조정 모드 ON"
                                      OffContent="조정 모드 OFF" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="프리셋 위치" FontWeight="SemiBold" />
                        <TextBlock Text="선택한 모니터의 네 꼭지점에 오버레이를 맞춥니다 (가장자리 여백 포함)."
                                   TextWrapping="Wrap" Opacity="0.75" FontSize="12" />
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <ComboBox Grid.Column="0" HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding Monitors}"
                                      SelectedItem="{Binding SelectedMonitor}" />
                            <Button Grid.Column="1" Content="새로고침" Command="{Binding RefreshMonitorsCommand}" />
                        </Grid>
                        <Grid ColumnDefinitions="Auto,120" ColumnSpacing="8">
                            <TextBlock Grid.Column="0" Text="가장자리 여백(px)" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Column="1" Minimum="0" Maximum="20" Increment="1"
                                           Value="{Binding PresetMargin}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                            <Button Grid.Row="0" Grid.Column="0" Content="↖ 좌상단"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    Command="{Binding SnapCornerCommand}" CommandParameter="TopLeft" />
                            <Button Grid.Row="0" Grid.Column="1" Content="↗ 우상단"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    Command="{Binding SnapCornerCommand}" CommandParameter="TopRight" />
                            <Button Grid.Row="1" Grid.Column="0" Content="↙ 좌하단"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    Command="{Binding SnapCornerCommand}" CommandParameter="BottomLeft" />
                            <Button Grid.Row="1" Grid.Column="1" Content="↘ 우하단"
                                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                    Command="{Binding SnapCornerCommand}" CommandParameter="BottomRight" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="불투명도" FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1" Text="{Binding OpacityPercent, StringFormat={}{0}%}" Opacity="0.8" />
                        </Grid>
                        <Slider Minimum="10" Maximum="100" TickFrequency="5"
                                Value="{Binding OpacityPercent}" />
                    </StackPanel>

                    <StackPanel Spacing="12">
                        <TextBlock Text="단축키" FontWeight="SemiBold" FontSize="14" />
                        <ToggleSwitch IsChecked="{Binding HotkeysEnabled}"
                                      OnContent="단축키 사용"
                                      OffContent="단축키 사용 안 함 (다른 앱과 충돌 시)" />
                        <TextBlock Text="끄면 아래 모든 단축키가 OS에 등록되지 않습니다. 조합은 그대로 저장되어 다시 켜면 복원됩니다."
                                   TextWrapping="Wrap" Opacity="0.75" FontSize="12" />
                        <StackPanel Spacing="12" IsEnabled="{Binding HotkeysEnabled}">
                            <ContentControl Content="{Binding ToggleHotkeyEditor}" ContentTemplate="{StaticResource HotkeyEditorTemplate}" />
                            <ContentControl Content="{Binding OpenSettingsHotkeyEditor}" ContentTemplate="{StaticResource HotkeyEditorTemplate}" />
                            <ContentControl Content="{Binding TimerToggleHotkeyEditor}" ContentTemplate="{StaticResource HotkeyEditorTemplate}" />
                            <ContentControl Content="{Binding TimerVisibilityHotkeyEditor}" ContentTemplate="{StaticResource HotkeyEditorTemplate}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="시간">
            <ScrollViewer>
                <StackPanel Margin="16" Spacing="20">
                    <CheckBox Content="24시간 형식" IsChecked="{Binding Use24Hour}" />

                    <StackPanel Spacing="6">
                        <TextBlock Text="세계 시간" FontWeight="SemiBold" />
                        <ToggleSwitch IsChecked="{Binding WorldClockEnabled}"
                                      OnContent="세계 시간 표시"
                                      OffContent="세계 시간 숨김" />
                        <Button Content="+ 항목 추가" Command="{Binding AddWorldClockCommand}" HorizontalAlignment="Left" />
                        <ItemsControl ItemsSource="{Binding WorldClockEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:WorldClockEntryViewModel">
                                    <Grid ColumnDefinitions="140,*,Auto" ColumnSpacing="8" Margin="0,4">
                                        <TextBox Grid.Column="0" Text="{Binding Label}" PlaceholderText="라벨" />
                                        <AutoCompleteBox Grid.Column="1"
                                                         Text="{Binding TimeZoneId}"
                                                         ItemsSource="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).AvailableTimeZoneIds}"
                                                         FilterMode="ContainsOrdinal"
                                                         PlaceholderText="TimeZone ID" />
                                        <Button Grid.Column="2" Content="X"
                                                Command="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).RemoveWorldClockCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="타이머">
            <ScrollViewer>
                <StackPanel Margin="16" Spacing="16">
                    <ToggleSwitch IsChecked="{Binding TimerEnabled}"
                                  OnContent="타이머 오버레이 표시"
                                  OffContent="타이머 오버레이 숨김" />

                    <CheckBox Content="알람 시 소리 재생" IsChecked="{Binding TimerSoundEnabled}" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="{Binding TimerToggleButtonText}" Command="{Binding ToggleTimerCommand}" MinWidth="80" />
                        <Button Content="정지" Command="{Binding StopTimerCommand}" />
                        <TextBlock Text="{Binding TimerStatus}" VerticalAlignment="Center" Opacity="0.85" />
                    </StackPanel>

                    <TextBlock Text="등록된 타이머는 단축키로 한 번에 시작·일시정지·재개됩니다. 각 타이머는 종료 시 각자 알람을 띄웁니다."
                               TextWrapping="Wrap" Opacity="0.75" FontSize="12" />

                    <Button Content="+ 타이머 추가" Command="{Binding AddTimerItemCommand}" HorizontalAlignment="Left" />

                    <ItemsControl ItemsSource="{Binding TimerItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="vm:TimerInstanceViewModel">
                                <Border BorderBrush="#40FFFFFF" BorderThickness="1" CornerRadius="4" Padding="12" Margin="0,4">
                                    <StackPanel Spacing="8">
                                        <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="8">
                                            <TextBlock Grid.Column="0" Text="라벨" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1" Text="{Binding Label}" PlaceholderText="옵션. 비우면 자동 라벨" />
                                            <Button Grid.Column="2" Content="삭제"
                                                    Command="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).RemoveTimerItemCommand}"
                                                    CommandParameter="{Binding}" />
                                        </Grid>

                                        <RadioButton GroupName="{Binding Id}"
                                                     Content="분 타이머"
                                                     IsChecked="{Binding ModeDuration}" />
                                        <Grid ColumnDefinitions="80,120,Auto" ColumnSpacing="8" Margin="24,0,0,0"
                                              IsEnabled="{Binding ModeDuration}">
                                            <TextBlock Grid.Column="0" Text="시간:" VerticalAlignment="Center" />
                                            <NumericUpDown Grid.Column="1" Minimum="0" Maximum="1440"
                                                           Value="{Binding DurationMinutes}" />
                                            <TextBlock Grid.Column="2" Text="분" VerticalAlignment="Center" />
                                        </Grid>

                                        <RadioButton GroupName="{Binding Id}"
                                                     Content="지정 시각 알람"
                                                     IsChecked="{Binding ModeClockTime}" />
                                        <Grid ColumnDefinitions="80,100,Auto,100,Auto" ColumnSpacing="8" Margin="24,0,0,0"
                                              IsEnabled="{Binding ModeClockTime}">
                                            <TextBlock Grid.Column="0" Text="시각:" VerticalAlignment="Center" />
                                            <NumericUpDown Grid.Column="1" Minimum="0" Maximum="23"
                                                           Value="{Binding ClockHour}" />
                                            <TextBlock Grid.Column="2" Text="시" VerticalAlignment="Center" />
                                            <NumericUpDown Grid.Column="3" Minimum="0" Maximum="59"
                                                           Value="{Binding ClockMinute}" />
                                            <TextBlock Grid.Column="4" Text="분" VerticalAlignment="Center" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="날씨">
            <ScrollViewer>
                <StackPanel Margin="16" Spacing="20">
                    <StackPanel Spacing="6">
                        <TextBlock Text="공통 설정" FontWeight="SemiBold" />
                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto,Auto" RowSpacing="8" ColumnSpacing="8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="API 키" VerticalAlignment="Center" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding ApiKey}" PlaceholderText="OpenWeatherMap API key" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="단위" VerticalAlignment="Center" />
                            <CheckBox Grid.Row="1" Grid.Column="1" Content="화씨(°F) 사용" IsChecked="{Binding UseFahrenheit}" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="갱신 주기(분)" VerticalAlignment="Center" />
                            <NumericUpDown Grid.Row="2" Grid.Column="1" Minimum="1" Maximum="120"
                                           Value="{Binding RefreshMinutes}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock Text="도시별 날씨 (최대 3곳)" FontWeight="SemiBold" />
                        <ToggleSwitch IsChecked="{Binding CityWeatherEnabled}"
                                      OnContent="날씨 표시"
                                      OffContent="날씨 숨김" />
                        <Button Content="+ 도시 추가" Command="{Binding AddCityWeatherCommand}" HorizontalAlignment="Left" />
                        <ItemsControl ItemsSource="{Binding CityWeatherEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="vm:CityWeatherEntryViewModel">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8" Margin="0,4">
                                        <TextBox Grid.Column="0" Text="{Binding CityName}" PlaceholderText="Seoul, Tokyo, London, ..." />
                                        <Button Grid.Column="1" Content="삭제"
                                                Command="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).RemoveCityWeatherCommand}"
                                                CommandParameter="{Binding}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Button Content="지금 갱신" Command="{Binding RefreshWeatherCommand}" HorizontalAlignment="Left" />
                </StackPanel>
            </ScrollViewer>
        </TabItem>

        <TabItem Header="시스템">
            <ScrollViewer>
                <StackPanel Margin="16" Spacing="16">
                    <ToggleSwitch IsChecked="{Binding SystemEnabled}"
                                  OnContent="시스템 지표 표시"
                                  OffContent="시스템 지표 숨김" />

                    <StackPanel Spacing="6" IsEnabled="{Binding SystemEnabled}">
                        <TextBlock Text="표시 항목" FontWeight="SemiBold" />
                        <CheckBox Content="메모리 사용률" IsChecked="{Binding ShowMemory}" />
                        <CheckBox Content="CPU 사용률" IsChecked="{Binding ShowCpuLoad}" />
                        <CheckBox Content="CPU 온도 (관리자 권한 필요)" IsChecked="{Binding ShowCpuTemp}" />
                        <CheckBox Content="GPU 온도/사용률 (관리자 권한 필요)" IsChecked="{Binding ShowGpuTemp}" />
                    </StackPanel>

                    <Grid ColumnDefinitions="120,120" ColumnSpacing="8" IsEnabled="{Binding SystemEnabled}">
                        <TextBlock Grid.Column="0" Text="갱신 주기(초)" VerticalAlignment="Center" />
                        <NumericUpDown Grid.Column="1" Minimum="1" Maximum="60"
                                       Value="{Binding SystemRefreshSeconds}" />
                    </Grid>

                    <Border BorderBrush="#FFEAB308" BorderThickness="1" CornerRadius="4" Padding="12"
                            IsVisible="{Binding NeedsElevationForTemps}">
                        <StackPanel Spacing="8">
                            <TextBlock TextWrapping="Wrap"
                                       Text="온도 지표는 관리자 권한이 있어야 읽을 수 있습니다. 아래 버튼을 누르면 관리자 권한으로 다시 실행합니다 (UAC 확인 필요)." />
                            <Button Content="관리자 권한으로 재시작" Command="{Binding RestartElevatedCommand}" HorizontalAlignment="Left" />
                        </StackPanel>
                    </Border>

                    <TextBlock TextWrapping="Wrap" Opacity="0.7" FontSize="12"
                               Text="메모리·CPU 사용률은 권한 없이 동작합니다. 온도는 LibreHardwareMonitor로 읽으며 부팅 자동시작 시에는 관리자 권한이 아니라 매번 재시작이 필요할 수 있습니다." />
                </StackPanel>
            </ScrollViewer>
        </TabItem>
    </TabControl>
</Window>
