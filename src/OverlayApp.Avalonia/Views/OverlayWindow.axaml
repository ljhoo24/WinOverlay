<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:OverlayApp.Core.ViewModels;assembly=OverlayApp.Core"
        mc:Ignorable="d"
        x:Class="OverlayApp.Avalonia.Views.OverlayWindow"
        x:DataType="vm:OverlayViewModel"
        Title="Overlay"
        WindowDecorations="None"
        TransparencyLevelHint="Transparent"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        MinWidth="80" MinHeight="40"
        Width="220" Height="80"
        Focusable="False">
    <Border Name="RootBorder"
            CornerRadius="8"
            Background="Black"
            BorderThickness="2"
            PointerPressed="OnPointerPressed"
            PointerMoved="OnPointerMoved">
        <Border.Styles>
            <Style Selector="Border#RootBorder">
                <Setter Property="BorderBrush" Value="Transparent" />
            </Style>
            <Style Selector="Border#RootBorder[Tag=adjust]">
                <Setter Property="BorderBrush" Value="#FFEAB308" />
            </Style>
        </Border.Styles>
        <Viewbox Stretch="Uniform" Margin="8">
            <StackPanel Spacing="2">
                <TextBlock Text="{Binding TimeText}"
                           Foreground="White"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <ItemsControl ItemsSource="{Binding WorldClockEntries}"
                              IsVisible="{Binding WorldClockVisible}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding DisplayText}"
                                       Foreground="#E0FFFFFF"
                                       FontSize="13" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding LocationWeatherText}"
                           IsVisible="{Binding LocationWeatherVisible}"
                           Foreground="#E0FFFFFF"
                           FontSize="13" />
                <TextBlock Text="{Binding CityWeatherText}"
                           IsVisible="{Binding CityWeatherVisible}"
                           Foreground="#E0FFFFFF"
                           FontSize="13" />
                <TextBlock Text="{Binding TimerText}"
                           IsVisible="{Binding TimerVisible}"
                           Foreground="#FFFEF3C7"
                           FontSize="13"
                           FontWeight="SemiBold" />
            </StackPanel>
        </Viewbox>
    </Border>
</Window>
